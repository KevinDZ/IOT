syntax = "v1"

type (
	// 车辆控制请求
	VehicleControlReq {
		VehicleID string `json:"vehicleID,validate=min=1"` // 车辆唯一标识
		Action    string `json:"action,validate=required"` // 动作：unlock_door, lock_door, start_engine
	}
	// 车辆控制响应
	VehicleControlResp {
		Code int    `json:"code"`
		Msg  string `json:"msg"`
	}
)

@server (
	prefix: /api/v1
	group:  vehicle
)
service mobile-api {
	@handler ControlVehicle
	post /vehicle/control (VehicleControlReq) returns (VehicleControlResp)
}

